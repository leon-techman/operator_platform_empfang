# === Google OAuth (Pflicht) ===
GOOGLE_CLIENT_ID=790308596407-3ttkst6rhs25kqjmjv17hhg13r5m1jmq.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dein-client-secret-aus-der-google-cloud-console

# Optional: nur setzen, falls die automatische Erkennung nicht passt
# GOOGLE_REDIRECT_URI=https://operator-platform-three.vercel.app/api/auth/callback

# === Session-Signatur (Pflicht) ===
# Beliebige lange Zufallszeichenkette, z.B. mit: openssl rand -hex 32
SESSION_SECRET=bitte-lange-zufalls-zeichenkette-eintragen

# === Token-Speicher: Vercel KV (Upstash Redis) ===
# Werden von Vercel automatisch gesetzt, sobald du im Projekt einen KV-/Upstash-Store anlegst und verbindest.
KV_REST_API_URL=
KV_REST_API_TOKEN=
